---
// src/components/Footer.astro
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const isKo = lang === 'ko';
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-flex">
      <!-- Branding Text -->
      <div class="footer-branding">
        <p class="brand-name">DSPAUT</p>
        <p class="brand-subtitle">{isKo ? "다운로드 자료실" : "Download Portal"}</p>
      </div>

      <!-- Copyright -->
      <div class="footer-copyright">
        <p>© 2026 SEONGSANLAB Co., Ltd. All rights reserved.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-secondary-bg);
    color: var(--color-text-secondary);
    border-top: 1px solid var(--color-border);
    padding: 48px 0;
    font-family: var(--font-sans);
    font-size: 14px;
  }

  .footer-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 48px;
  }

  @media (max-width: 768px) {
    .footer-container {
      padding: 0 24px;
    }
  }

  .footer-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  @media (max-width: 768px) {
    .footer-flex {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }
  }

  .footer-branding {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  @media (max-width: 768px) {
    .footer-branding {
      align-items: center;
    }
  }

  .brand-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 4px;
    font-family: var(--font-display);
  }

  .brand-subtitle {
    font-size: 14px;
    color: var(--color-text-secondary);
    opacity: 0.8;
  }

  .footer-copyright {
    color: var(--color-text-secondary);
    opacity: 0.8;
  }
</style>
